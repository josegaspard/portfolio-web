{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/:all*(svg|jpg|jpeg|png|webp|avif|gif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(svg|jpg|jpeg|png|webp|avif|gif|ico)(?:/)?$"
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/_next/static(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin-when-cross-origin"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/content/edit/[id]",
      "regex": "^/admin/content/edit/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/content/edit/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/admin/portfolio/[id]",
      "regex": "^/admin/portfolio/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/portfolio/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portafolio/[slug]",
      "regex": "^/portafolio/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/portafolio/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[slug]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/analytics",
      "regex": "^/admin/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/analytics(?:/)?$"
    },
    {
      "page": "/admin/content",
      "regex": "^/admin/content(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/content(?:/)?$"
    },
    {
      "page": "/admin/content/new",
      "regex": "^/admin/content/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/content/new(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/database",
      "regex": "^/admin/database(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/database(?:/)?$"
    },
    {
      "page": "/admin/mailing",
      "regex": "^/admin/mailing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/mailing(?:/)?$"
    },
    {
      "page": "/admin/media",
      "regex": "^/admin/media(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/media(?:/)?$"
    },
    {
      "page": "/admin/messages",
      "regex": "^/admin/messages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/messages(?:/)?$"
    },
    {
      "page": "/admin/notifications",
      "regex": "^/admin/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/notifications(?:/)?$"
    },
    {
      "page": "/admin/portfolio",
      "regex": "^/admin/portfolio(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/portfolio(?:/)?$"
    },
    {
      "page": "/admin/settings",
      "regex": "^/admin/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/settings(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/portafolio",
      "regex": "^/portafolio(?:/)?$",
