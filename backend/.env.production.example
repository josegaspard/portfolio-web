# Production Environment Variables - Backend
# Copy this file to .env and update with your production values

# Resend Email Service
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=hola@josegaspard.dev

# Frontend URL (for CORS)
FRONTEND_URL=https://josegaspard.dev

# Database
DATABASE_URL=sqlite:database.sqlite

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=change-this-to-a-very-secure-random-string-in-production

# Environment
NODE_ENV=production

# Port (Hostinger assigns this automatically)
PORT=4000
